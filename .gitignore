# --- Laravel Core ---
/node_modules
/vendor
.env
.env.backup
.env.production
.phpactor.json
.phpunit.result.cache
*.log

# --- IDE & System Files ---
/.fleet
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
/auth.json
Homestead.json
Homestead.yaml
Thumbs.db
.DS_Store
**/.DS_Store
**/Thumbs.db

# --- AdminLTE & Asset Handling ---
# Blocks the heavy template folders you downloaded
/public/vendor
/public/dist
/public/plugins
/public/asset/dist
/public/asset/docs
/public/asset/plugins

# Blocks compiled files (Vite/Mix) - these rebuild on the server
/public/build
/public/hot

# --- Storage & Uploads ---
/public/storage
/storage/*.key
/storage/pail
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*.php
/storage/logs/*.log

# Prevent personal uploads from going to GitHub
/storage/app/public/*
!/storage/app/public/.gitignore
